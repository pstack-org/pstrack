	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --turbopack",
		"postinstall": "prisma generate --schema=./src/prisma/schema.prisma",
		"build": "next build",
		"start": "next start",
		"prod": "vercel --prod",
		"prev": "vercel",
		"lint": "next lint",
		"prettier:check": "prettier --check .",
		"prettier:fix": "prettier --write .",
		"tsc": "tsc --noEmit",
		"prisma:generate": "prisma generate --schema=./src/server/prisma/schema.prisma",
		"prisma:migrate:dev": "prisma migrate dev --name init --schema=./src/server/prisma/schema.prisma",
		"prisma:migrate:deploy": "prisma migrate deploy --schema=./src/server/prisma/schema.prisma",
		"prisma:studio": "prisma studio --schema=./src/server/prisma/schema.prisma",
		"prisma:push": "prisma db push --schema=./src/server/prisma/schema.prisma",
		"prisma:pull": "prisma db pull --schema=./src/server/prisma/schema.prisma"
	},
